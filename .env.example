# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Vercel Blob ───────────────────────────────────────────────────────────────
# Auto-populated in Vercel deployments; set manually for local dev
# Get from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-token

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Langfuse (LLM observability — free tier: langfuse.com) ───────────────────
LANGFUSE_SECRET_KEY=sk-lf-your-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google AI (RAG embeddings — gemini-embedding-001) ────────────────────────
# Get from: https://aistudio.google.com/apikey — no GCP project needed
GOOGLE_API_KEY=AIza-your-key

# ── MCP Server ────────────────────────────────────────────────────────────────
# Optional local-dev shortcut — accepted as a valid bearer token without a DB lookup.
# In production, users create per-user keys from /settings/mcp instead.
# MCP_API_KEY=
